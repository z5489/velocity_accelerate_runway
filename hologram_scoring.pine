//@version=5
indicator("Hologram Quant Scoring System", overlay=true, precision=2)

// ==========================================
// METRIC CALCULATIONS
// ==========================================

// 1. Velocity (5-Day ROC%)
velocity_raw = ta.roc(close, 5)

// 2. Acceleration (MACD Histogram Delta)
[macdLine, signalLine, hist] = ta.macd(close, 12, 26, 9)
accel_raw = hist - hist[1]

// 3. Runway (14-Day RSI)
rsi_val = ta.rsi(close, 14)

// ==========================================
// SCORING COMPONENTS (0-100)
// ==========================================

// --- Long Components ---
v_score_long = math.min(100.0, math.max(0.0, (velocity_raw / 5.0) * 100.0))
a_score_long = accel_raw > 0 ? 100.0 : 30.0

// --- Bearish Components ---
v_score_bear = math.min(100.0, math.max(0.0, (-velocity_raw / 5.0) * 100.0))
a_score_bear = accel_raw < 0 ? 100.0 : 30.0

// ==========================================
// PROFILE TOTALS
// ==========================================

// 1. Aggressive Momentum Chaser
r_agg = rsi_val <= 80 ? 100.0 : math.max(0.0, 100.0 * (100.0 - rsi_val) / 20.0)
score_aggressive = (0.40 * v_score_long) + (0.40 * a_score_long) + (0.20 * r_agg)

// 2. Balanced Swing Trader
r_bal = 100.0 * math.exp(-(math.pow(rsi_val - 60.0, 2)) / (2.0 * math.pow(15.0, 2)))
score_balanced = (0.35 * v_score_long) + (0.35 * a_score_long) + (0.30 * r_bal)

// 3. Mean-Reversion Trader
r_mean = rsi_val <= 30 ? 100.0 : math.max(0.0, 100.0 * (100.0 - rsi_val) / 70.0)
score_mean = (0.15 * v_score_long) + (0.35 * a_score_long) + (0.50 * r_mean)

// 4. Bearish Short
r_bear = 100.0 * math.exp(-(math.pow(rsi_val - 70.0, 2)) / (2.0 * math.pow(15.0, 2)))
score_bearish = (0.35 * v_score_bear) + (0.35 * a_score_bear) + (0.30 * r_bear)

// ==========================================
// VISUALIZATION (NUMERICAL ONLY)
// ==========================================

// Dashboard Table (Top Right) - The primary numerical output
// We use overlay=true and remove all plot() calls to ensure no graphs appear
var table scoreTable = table.new(position.top_right, 2, 8, bgcolor=color.rgb(20, 20, 20), border_width=1)
if barstate.islast
    table.cell(scoreTable, 0, 0, "Metric", text_color=color.white)
    table.cell(scoreTable, 1, 0, "Value", text_color=color.white)
    
    table.cell(scoreTable, 0, 1, "Velocity (ROC%)", text_color=color.gray)
    table.cell(scoreTable, 1, 1, str.tostring(velocity_raw, "#.##") + "%", text_color=color.white)
    
    table.cell(scoreTable, 0, 2, "Acceleration", text_color=color.gray)
    table.cell(scoreTable, 1, 2, str.tostring(accel_raw, "#.####"), text_color=color.white)
    
    table.cell(scoreTable, 0, 3, "RSI", text_color=color.gray)
    table.cell(scoreTable, 1, 3, str.tostring(rsi_val, "#.##"), text_color=color.white)
    
    table.cell(scoreTable, 0, 4, "Aggressive Score", text_color=color.green)
    table.cell(scoreTable, 1, 4, str.tostring(score_aggressive, "#.##"), text_color=color.white)
    
    table.cell(scoreTable, 0, 5, "Balanced Score", text_color=color.blue)
    table.cell(scoreTable, 1, 5, str.tostring(score_balanced, "#.##"), text_color=color.white)
    
    table.cell(scoreTable, 0, 6, "Mean-Rev Score", text_color=color.yellow)
    table.cell(scoreTable, 1, 6, str.tostring(score_mean, "#.##"), text_color=color.white)
    
    table.cell(scoreTable, 0, 7, "Bearish Score", text_color=color.red)
    table.cell(scoreTable, 1, 7, str.tostring(score_bearish, "#.##"), text_color=color.white)
